generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  // 帳號登入用（Google 使用者可為空）
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       StudentProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StudentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  entryYear       Int      @default(113)
  currentGrade    Int      @default(1)
  expectedGradYear Int?
  displayName     String?
  currentTerm     String   @default("114-2")
  gpaScale        String   @default("percent")
  includeFailInAvg Boolean @default(true)
  themeColor      String   @default("mint")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments     Enrollment[]
  selectedPrograms UserProgram[]
  scheduleEntries ScheduleEntry[]
  scheduleTermSettings ScheduleTermSetting[]
  scheduleMarks   ScheduleMark[]
  scheduleTodos   ScheduleTodo[]
  scheduleHolidays ScheduleHoliday[]
}

model Program {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        String
  shortLabel  String?
  version     String   @default("113")
  description String?
  totalCredits Int?
  sortOrder   Int      @default(0)

  groups      RequirementGroup[]
  courses     Course[]
  prereqs     Prerequisite[]
  nonCredits  NonCreditRequirement[]
  users       UserProgram[]
}

model UserProgram {
  id        String   @id @default(cuid())
  profileId String
  programId String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  profile StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  program Program        @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([profileId, programId])
}

model RequirementGroup {
  id          String  @id @default(cuid())
  programId   String
  code        String
  name        String
  blockName   String?
  minCredits  Int     @default(0)
  maxCredits  Int?
  description String?
  sortOrder   Int     @default(0)

  program Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  courses Course[]

  @@unique([programId, code])
}

model Course {
  id        String  @id @default(cuid())
  programId String
  groupId   String?
  code      String
  name      String
  credits   Float
  notes     String?

  program Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  group   RequirementGroup? @relation(fields: [groupId], references: [id])
  enrollments Enrollment[]
  prereqOf    Prerequisite[] @relation("CoursePrereqOf")
  requires    Prerequisite[] @relation("CourseRequires")

  @@unique([programId, code])
}

model Prerequisite {
  id              String  @id @default(cuid())
  programId       String
  courseId        String
  requiredCourseId String
  note            String?

  program        Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  course         Course  @relation("CoursePrereqOf", fields: [courseId], references: [id], onDelete: Cascade)
  requiredCourse Course  @relation("CourseRequires", fields: [requiredCourseId], references: [id], onDelete: Cascade)

  @@unique([courseId, requiredCourseId])
}

model NonCreditRequirement {
  id          String  @id @default(cuid())
  programId   String
  code        String
  name        String
  description String?
  sortOrder   Int     @default(0)

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, code])
}

model Enrollment {
  id            String   @id @default(cuid())
  profileId     String
  courseId      String?
  customName    String?
  customCode    String?
  credits       Float
  term          String
  status        String   @default("taken")
  score         Float?
  letterGrade   String?
  countInAvg    Boolean  @default(true)
  categoryCode  String?
  programCode   String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course  Course?        @relation(fields: [courseId], references: [id])
}

// 使用者自行建立的學期課表時段
model ScheduleEntry {
  id         String   @id @default(cuid())
  profileId  String
  term       String
  courseName String
  teacher    String   @default("")
  room       String   @default("")
  // 選修／本系等標籤，顯示於課名後方【】
  tag        String?
  // 星期：1=一 … 7=日
  weekday    Int
  // JSON 陣列，如 [3,4] 表示第 3–4 節
  periods    String
  color      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, term])
}

// 各學期課表設定（第 1 週起始日等）
model ScheduleTermSetting {
  id          String   @id @default(cuid())
  profileId   String
  term        String
  // 第 1 週星期一的日期 YYYY-MM-DD
  week1Start  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, term])
}

// 週課表標記：備忘錄／放假／段考／交作業／重要備註
model ScheduleMark {
  id        String   @id @default(cuid())
  profileId String
  term      String
  week      Int
  // 1=一 … 7=日
  weekday   Int
  // null = 整天
  period    Int?
  // memo | holiday | exam | homework | important
  kind      String
  content   String   @default("")
  // red | orange | yellow | green | blue | purple
  color     String   @default("blue")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, term, week])
}

// 週課表 TO DO LIST
model ScheduleTodo {
  id        String   @id @default(cuid())
  profileId String
  term      String
  week      Int
  content   String
  // red=非常緊急 | orange=急 | green=普通
  priority  String   @default("green")
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, term, week])
}

// 手動設定的國定假日
model ScheduleHoliday {
  id        String   @id @default(cuid())
  profileId String
  // YYYY-MM-DD
  date      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
}
